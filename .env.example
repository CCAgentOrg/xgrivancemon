# XGrivanceMon Environment Configuration

# Database (TursoDB)
TURSO_URL=libsql://xgrivancemon-yourusername.turso.io
TURSO_TOKEN=your-turso-token-here

# X API Credentials
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret

# Scheduling (24-hour format)
COLLECTION_HOUR=9
REPORT_DAY=thu
REPORT_HOUR=10

# App Settings
DEBUG=false
LOG_LEVEL=INFO
